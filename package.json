{
  "name": "collectif-badge-",
  "private": true,
  "version": "0.0.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "vite --port 5173",
    "dev:web:api": "node server/web-api.cjs",
    "dev:webapp": "concurrently -k \"npm:dev:web\" \"npm:dev:web:api\"",
    "serve:webapp": "npm run build:web && node server/web-api.cjs",
    "dev": "concurrently -k \"npm:dev:web\" \"wait-on tcp:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:web": "tsc -b && vite build",
    "build": "npm run sync:version && npm run build:web && electron-builder --publish never",
    "sync:version": "node scripts/check-version-sync.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/archivo-narrow": "^5.2.8",
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.10.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.10",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "ch.collectif.badgeapp",
    "productName": "Collectif Badge",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "LOGO/app.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis",
      "icon": "LOGO/app.ico"
    }
  }
}
